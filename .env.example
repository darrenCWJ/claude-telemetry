# Copy to .env and fill in values
# docker-compose reads this file automatically

# ClickHouse password (used by both ClickHouse and the OTEL Collector)
CLICKHOUSE_PASSWORD=otel_secret

# OTEL Collector endpoint (used by hooks and SDK apps)
# Default points to local Docker Compose setup
OTEL_ENDPOINT=http://localhost:4318

# Grafana admin password (default: admin)
GRAFANA_ADMIN_PASSWORD=admin
